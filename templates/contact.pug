doctype html
html(lang="en")
  head
    include templates/_partials/_head.jade
  body
    include templates/_partials/_nav.jade
    main
      section.contact-page
        h1.pixel-heading Contact Us
        p.section-subtitle Got a question? Want to collaborate? Just wanna say hi?
        form#contact-form.contact-form
          div.contact-error#contact-error(style="display:none")
          div.form-group
            label(for="name") Name *
            input#name(type="text", name="name", required, placeholder="Your name")
          div.form-group
            label(for="email") Email *
            input#email(type="email", name="email", required, placeholder="you@example.com")
          div.form-group
            label(for="subject") Subject
            input#subject(type="text", name="subject", placeholder="What's this about?")
          div.form-group
            label(for="message") Message *
            textarea#message(name="message", required, rows="6", placeholder="Tell us what's on your mind...")
          button#contact-submit.pixel-btn(type="submit") Send Message
        div.contact-success#contact-success(style="display:none")
          h2 ✅ Message Sent!
          p Thanks for reaching out. We'll get back to you as soon as we can.
    include templates/_partials/_footer.jade
    include templates/_partials/_overlays.jade
    script(src=.DistJS)
