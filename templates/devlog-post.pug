doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{.Title}
    meta(name="description", content=.Description)
    meta(name="theme-color", content="#1a1a2e")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=IBM+Plex+Mono&display=swap")
    link(rel="stylesheet", href=.DistCSS)
  body
    nav#navbar.pixel-nav
      div.nav-inner
        a.logo-link(href="/")
          img.nav-logo(src=.LogoPath, alt=.Studio, width="48", height="41")
          span.nav-brand #{.Studio}
        button#nav-toggle.mobile-toggle(aria-label="Toggle menu")
          span
          span
          span
        ul.nav-links
          li: a(href="/") Home
          li: a(href="/devlog", class="active") Devlog
          li: a(href="/working-on") WIP
          li: a(href="/press-kit") Press Kit
          li: a(href="/contact") Contact

    main
      article.devlog-article
        a.devlog-back(href="/devlog") &larr; Back to Devlog
        if .Post
          header.devlog-header
            h1.pixel-heading #{.Post.Title}
            time.devlog-date(datetime=.Post.RawDate) #{.Post.FormattedDate}
          div.devlog-content #{.Post.Content}

    footer.pixel-footer
      div.footer-inner
        div.footer-brand
          img.footer-logo(src=.LogoPath, alt=.Studio, width="64", height="54")
          p #{.Tagline}
        div.footer-socials
          if .Socials.Twitter
            a.social-link(href=.Socials.Twitter, target="_blank", rel="noopener", aria-label="Twitter")
            svg.social-icon(viewBox="0 0 24 24", width="18", height="18")
              path(d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z", fill="currentColor")
          if .Socials.Itchio
                        a.social-link(href=.Socials.Itchio, target="_blank", rel="noopener", aria-label="itch.io")
              svg.social-icon(viewBox="0 0 24 24", width="18", height="18")
                path(d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-5 7H8v-2h8v2zm3-4h-2V7h2v2zm-12 0H5V7h2v2z", fill="currentColor")
          if .Socials.Discord
                        a.social-link(href=.Socials.Discord, target="_blank", rel="noopener", aria-label="Discord")
              svg.social-icon(viewBox="0 0 24 24", width="18", height="18")
                path(d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z", fill="currentColor")
          if .Socials.Github
                        a.social-link(href=.Socials.Github, target="_blank", rel="noopener", aria-label="GitHub")
              svg.social-icon(viewBox="0 0 24 24", width="18", height="18")
                path(d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z", fill="currentColor")
          if .Socials.Email
                        a.social-link(href=.SocialMailto, aria-label="Email")
              svg.social-icon(viewBox="0 0 24 24", width="18", height="18")
                path(d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z", fill="currentColor")
        div.footer-bottom
          p &copy; #{.Studio} &mdash; Brothers make games
          button#crt-toggle.crt-toggle(title="Toggle CRT effect") TV CRT OFF

    div#konami-overlay.konami-overlay(aria-hidden="true")
      div.konami-content
        h2.konami-title 🏆 Secret Found!
        p You discovered the Konami Code easter egg!
        p.konami-sub The bros salute you. 🖥️
        button#konami-close.pixel-btn Close

    div#toast-container.toast-container(aria-live="polite")
    div#crt-overlay.crt-overlay(aria-hidden="true")
    div#cursor-trail(aria-hidden="true")

    script(src=.DistJS)
