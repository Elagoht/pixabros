doctype html
html(lang="en")
  head
    include templates/_partials/_head.jade
  body
    include templates/_partials/_nav.jade
    main
      section.hero
        div.hero-content
          img.hero-logo(src=.LogoPath, alt="PixaBros logo", width="280", height="238")
          h1.hero-tagline#typewriter(data-text=.Tagline)
          p.hero-sub #{.Description}
          a.arcade-btn.arcade-btn-cyan(href="/play") ▶ Insert Coin

      section.section-frame#about
        div.section-inner
          header.section-header
            p.section-eyebrow The Studio
            h2 Meet the Bros
          div.bros-grid
            each bro in .Bros
              div.bro-card
                div.bro-avatar-frame
                  if .Avatar
                    img.bro-avatar(src=.Avatar, alt=.Name, width="112", height="112")
                  else
                    div.bro-avatar-placeholder #{.Initials}
                h3.bro-name #{.Name}
                div.bro-roles
                  each r in .Roles
                    span.tag-badge #{.}
                p.bro-bio #{.Bio}

      section.section-frame#games
        div.section-inner
          header.section-header
            p.section-eyebrow Portfolio
            h2 Our Games
            p.section-subtitle #{len .Games} games, two brothers, infinite passion
          div.games-grid
            each game in .Games
              div.game-card(data-title=.Title, data-genre=.Genre, data-desc=.Description, data-image=.ImageURL, data-year=.Year, data-itch=.ItchURL)
                div.game-card-frame
                  img.game-thumb(src=.ImageURL, alt=.Title, loading="lazy", width="400", height="225")
                  div.game-card-overlay
                    span.game-card-title #{.Title}
                    span.game-card-genre #{.Genre}
                    span.game-card-year #{.Year}

      // Game Detail Modal
      div.game-modal#game-modal(aria-hidden="true")
        div.game-modal-backdrop
        div.game-modal-dialog
          button.game-modal-close(aria-label="Close") ×
          img.game-modal-image(src="", alt="")
          div.game-modal-info
            h2.game-modal-title
            span.game-modal-genre
            span.game-modal-year
            p.game-modal-desc
            div.game-modal-links

      section.cta-banner
        h2 #{.Studio}
        p.cta-text #{.Tagline}
        if .Socials.Email
          a.arcade-btn(href=.SocialMailto) Get in Touch

    include templates/_partials/_footer.jade
    include templates/_partials/_overlays.jade
    script(src=.DistJS)
