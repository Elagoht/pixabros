doctype html
html(lang="en")
  head
    include templates/_partials/_head.jade
  body
    include templates/_partials/_nav.jade
    main
      section.wip-page
        h1.pixel-heading What We&rsquo;re Working On
        p.section-subtitle A sneak peek at what&rsquo;s cooking in the PixaBros kitchen
        if .WorkingOn
          div.wip-grid
            each project in .WorkingOn
              div.wip-card
                if .Image
                  img.wip-image(src=.Image, alt=.Title)
                else
                  div.wip-image-placeholder 🚧
                div.wip-info
                  h2.wip-title #{.Title}
                  div.wip-tags
                    each tag in .Tags
                      span.wip-tag #{.}
                  p.wip-desc #{.Description}
                  div.wip-progress
                    div.wip-progress-bar(style=.ProgressStyle)
                    span.wip-progress-text #{.Progress}%
                  span.wip-status #{.Status}
        else
          div.empty-state
            p Nothing to show right now. We&rsquo;re busy cooking!
            p.empty-icon 🍳
    include templates/_partials/_footer.jade
    include templates/_partials/_overlays.jade
    script(src=.DistJS)
